# ── Gmail OAuth2 (personal @gmail.com) ────────────────────────────────────────
# Get these from Google Cloud Console → OAuth 2.0 Client IDs
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
# Run scripts/gmail_auth.py once to generate this file
GMAIL_TOKEN_FILE=data/gmail_token.json
# The Gmail account Nexus monitors
GMAIL_MONITORED_ACCOUNT=technobrain6@gmail.com
# Gmail label Nexus filters on (create this label in Gmail → Settings)
GMAIL_LABEL=nexus-contact-form

# ── LLM (choose one) ──────────────────────────────────────────────────────────
# Option A: Groq (free tier, fast)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# Option B: Ollama (local, free, no API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Set to "groq" or "ollama"
LLM_PROVIDER=groq

# ── Qdrant vector store ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=salesmate_knowledge

# ── Embedding model (Ollama, free local) ──────────────────────────────────────
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# ── Salesmate CRM ──────────────────────────────────────────────────────────────
SALESMATE_API_KEY=your-salesmate-api-key
SALESMATE_LINKNAME=technobrain.salesmate.io

# ── PostgreSQL (from your Next.js project) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/techno_brain_forms

# ── Next.js form API (Nexus POLLs this for submissions) ───────────────────────
FORM_API_URL=http://localhost:3000
FORM_API_KEY=your-agent-api-key-from-nextjs-env

# ── Nexus server ──────────────────────────────────────────────────────────────
NEXUS_PORT=8000
NEXUS_SECRET=change-this-long-random-secret
# For Gmail push notifications (production only) — needs public HTTPS URL
NEXUS_PUBLIC_URL=https://nexus.yourserver.com

# ── Polling interval (seconds) — 60 for production, 30 for dev ───────────────
POLL_INTERVAL=60
